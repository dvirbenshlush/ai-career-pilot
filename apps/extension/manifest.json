{
  "manifest_version": 3,
  "name": "AI Career Pilot",
  "version": "1.0.0",
  "description": "שלח קו\"ח והכן לראיון ישירות מדפי משרות",
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Career Pilot"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage", "activeTab", "tabs", "clipboardWrite"],
  "externally_connectable": {
    "matches": ["https://ai-career-pilot-web.vercel.app/*"]
  },
  "host_permissions": [
    "https://ai-career-pilot-web.vercel.app/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'"
  }
}

{
  "name": "ai-career-pilot",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/web",
    "dev:messaging": "npm run dev --prefix services/messaging",
    "dev:all": "concurrently --names \"web,messaging\" --prefix-colors \"cyan,green\" \"npm run dev --workspace=apps/web\" \"npm run dev --prefix services/messaging\"",
    "build": "npm run build --workspace=apps/web",
    "lint": "npm run lint --workspace=apps/web"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
